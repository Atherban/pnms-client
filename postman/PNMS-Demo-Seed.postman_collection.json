{
  "info": {
    "name": "PNMS Demo Seed",
    "description": "Seed minimal demo data for PNMS (5-10 records per module). Run folders top-to-bottom.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" },
    { "key": "email", "value": "test@example.com" },
    { "key": "password", "value": "test_pass" },
    { "key": "token", "value": "" },

    { "key": "plant_type_tomato_id", "value": "" },
    { "key": "plant_type_chilli_id", "value": "" },
    { "key": "plant_type_marigold_id", "value": "" },
    { "key": "plant_type_rose_id", "value": "" },
    { "key": "plant_type_coriander_id", "value": "" },

    { "key": "seed_tomato_id", "value": "" },
    { "key": "seed_chilli_id", "value": "" },
    { "key": "seed_marigold_id", "value": "" },
    { "key": "seed_rose_id", "value": "" },
    { "key": "seed_coriander_id", "value": "" },

    { "key": "customer_greenleaf_id", "value": "" },
    { "key": "customer_sunrise_id", "value": "" },
    { "key": "customer_happyhome_id", "value": "" },
    { "key": "customer_cityflora_id", "value": "" },
    { "key": "customer_bloommart_id", "value": "" },

    { "key": "inventory_tomato_id", "value": "" },
    { "key": "inventory_chilli_id", "value": "" },
    { "key": "inventory_marigold_id", "value": "" },
    { "key": "inventory_rose_id", "value": "" },
    { "key": "inventory_coriander_id", "value": "" }
  ],
  "item": [
    {
      "name": "00 - Auth",
      "item": [
        {
          "name": "Login",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const r = pm.response.json();",
                  "const payload = r?.data ?? r;",
                  "const token = payload?.token;",
                  "if (token) pm.collectionVariables.set('token', token);",
                  "pm.test('Token captured', () => pm.expect(token).to.be.a('string').and.not.empty);"
                ]
              }
            }
          ]
        }
      ]
    },
